{
	"name": "pipi",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"bench:llm": "node scripts/benchmark-llm-concurrency.mjs",
		"bench:stt": "node scripts/benchmark-stt.mjs",
		"bench:tts": "node scripts/benchmark-tts-concurrency.mjs",
		"compile:client": "esbuild src/client/index.ts --bundle --format=esm --target=es2022 --outfile=public/app.js",
		"submodules": "git submodule update --init --recursive",
		"build:stt-parakeet-cpp": "cmake -S native/parakeet-cpp-stt -B native/parakeet-cpp-stt/build && cmake --build native/parakeet-cpp-stt/build -j",
		"build:tts-rust": "npm run submodules -- native/qwen3_tts_rs && cargo build --release --no-default-features --features mlx --manifest-path native/qwen3_tts_rs/Cargo.toml --bin pibot-tts-worker",
		"build:tts-cpp": "node scripts/build-qwen3-tts-cpp.mjs",
		"build:native": "node scripts/build-native.mjs",
		"build:natives": "node scripts/build-native.mjs",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit && npm run compile:client",
		"typecheck": "tsc --noEmit",
		"prepare": "husky"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "0.78.1",
		"@earendil-works/pi-ai": "0.78.1",
		"@mozilla/readability": "^0.6.0",
		"jsdom": "^29.1.1",
		"tsx": "4.22.1",
		"turndown": "^7.2.4",
		"turndown-plugin-gfm": "^1.0.2",
		"typescript": "5.9.3",
		"ws": "8.18.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/jsdom": "^28.0.3",
		"@types/node": "24.0.0",
		"@types/turndown": "^5.0.6",
		"@types/ws": "8.5.13",
		"concurrently": "9.2.1",
		"esbuild": "0.28.0",
		"husky": "9.1.7"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
