# ─── Auth ────────────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ─── LLM: local (llama.cpp) ──────────────────────────────────────────────────
# Model to run locally. Options: gemma (26B, default), gemma12b (12B), qwen
# LOCAL_LLM=gemma12b

# Context window size passed to llama.cpp
LLAMA_CONTEXT_WINDOW=10000

# Override the auto-downloaded llama.cpp binary
# LLAMA_CPP_BINARY_PATH=/path/to/llama-server

# Override model directory (default: ~/models/<model-dir-name>)
# LLAMA_MODEL_DIR=/path/to/models

# ─── LLM: cloud provider (optional, overrides local) ─────────────────────────
# Set PI_PROVIDER to switch from local to a cloud LLM.
# Options: anthropic, openai (and any provider supported by pi-ai)
# PI_PROVIDER=anthropic
# PI_MODEL=claude-sonnet-4-5

# API keys — only the key matching PI_PROVIDER is required
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── llama.cpp server (only relevant when using local LLM) ───────────────────
# LLAMA_HOST=127.0.0.1
# LLAMA_PORT=8080
# LLAMA_BASE_URL=http://127.0.0.1:8080/v1

# ─── TTS ─────────────────────────────────────────────────────────────────────
# Backend to use. Options: cpp (default), rust, python, disabled
# QWEN3_TTS_WORKER=cpp

# Language for TTS synthesis
# QWEN3_TTS_LANGUAGE=de

# Reference voice for voice cloning (WAV file + transcript)
# QWEN3_TTS_REF_AUDIO=data/voices/elevenlabs-pibot-reference-de.wav
# QWEN3_TTS_REF_TEXT_FILE=data/voices/elevenlabs-pibot-reference-de.txt

# Seed for reproducible voice output
# QWEN3_TTS_SEED=1234

# Model name (mlx/HuggingFace repo)
# QWEN3_TTS_MODEL_NAME=mlx-community/Qwen3-TTS-12Hz-0.6B-Base-6bit

# Paths to compiled TTS workers and model files (defaults to native/ build output)
# QWEN3_TTS_CPP_WORKER_PATH=
# QWEN3_TTS_CPP_MODEL_PATH=
# QWEN3_TTS_RUST_WORKER_PATH=
# QWEN3_TTS_RUST_MODEL_PATH=
# QWEN3_TTS_PYTHON_COMMAND=uv
# QWEN3_TTS_PYTHON_WORKER_PATH=

# ─── STT ─────────────────────────────────────────────────────────────────────
# Paths to Parakeet worker and model (defaults to native/ build output and ~/models/)
# PARAKEET_CPP_WORKER_PATH=
# PARAKEET_CPP_MODEL_PATH=
# PARAKEET_CPP_MODEL_FILE=tdt-0.6b-v3-q8_0.gguf

# Path to Silero VAD model (default: ~/models/whisper-vad/ggml-silero-v6.2.0.bin)
# SILERO_VAD_GGML_MODEL_PATH=
# SILERO_VAD_GGML_MODEL_FILE=ggml-silero-v6.2.0.bin

# ─── Web search ──────────────────────────────────────────────────────────────
BRAVE_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT=8010
# HOST=0.0.0.0

# HTTPS (recommended when accessing from other devices on the network)
# Generate with: openssl req -x509 -newkey rsa:2048 -keyout data/ssl/key.pem \
#   -out data/ssl/cert.pem -days 3650 -nodes -subj "/CN=pibot-local" \
#   -addext "subjectAltName=IP:<your-local-ip>,IP:127.0.0.1,DNS:localhost"
# SSL_KEY_FILE=data/ssl/key.pem
# SSL_CERT_FILE=data/ssl/cert.pem

# Set to 1 when running over HTTPS to mark session cookies as Secure
# SECURE_COOKIES=1

# ─── Storage ─────────────────────────────────────────────────────────────────
# PIBOT_CACHE_DIR=~/.cache/pibot
# USERS_FILE=data/users.json
# SESSIONS_FILE=data/sessions.json
# USER_MEMORY_DIR=data/user-memories

# Maximum number of images kept in the agent context window
# MAX_CONTEXT_IMAGES=4

# ─── Misc ────────────────────────────────────────────────────────────────────
# MEMORY_FILE=data/memories.json
